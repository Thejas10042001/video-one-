# Google OAuth Credentials
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# The full callback URL. Must match Authorized Redirect URIs in Google Console.
# Example: https://your-app.vercel.app/auth/google/callback
GOOGLE_REDIRECT_URI=


# Google Drive API Key (for the Picker)
# Enable "Google Picker API" and "Google Drive API" in Google Console.
VITE_GOOGLE_DRIVE_API_KEY=


# Secret for session encryption
SESSION_SECRET=

